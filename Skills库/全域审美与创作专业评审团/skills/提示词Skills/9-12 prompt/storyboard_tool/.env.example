# CineBoard Pro - AI服务配置
# 复制此文件为 .env 并填写你的API密钥

# ============================================
# Gemini 3 配置
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-pro
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ============================================
# API聚合平台配置
# ============================================
AGGREGATOR_ENABLED=false
AGGREGATOR_BASE_URL=https://api.aggregator.com/v1
AGGREGATOR_API_KEY=your_aggregator_api_key_here

# ============================================
# 图像生成配置
# ============================================
# 图像提供商: midjourney / dall-e / stable-diffusion
IMAGE_PROVIDER=midjourney

# ============================================
# 通用AI配置
# ============================================
AI_TIMEOUT=60
AI_MAX_RETRIES=3
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096
AI_ENABLE_CACHE=true
